{
  "name": "hjulverkstan-web",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --inspect --env-file=../.env scripts/dev",
    "debug": "node --inspect-brk scripts/dev",
    "build:ssr": "vite build --ssr src/server.tsx --outDir dist/ssr",
    "build:static": "vite build --outDir dist/static && node scripts/build",
    "build": "npm run build:ssr && npm run build:static",
    "serve": "node scripts/serve.js",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx,md}\"",
    "lint:fix": "eslint --fix \"**/*.{js,jsx,ts,tsx,md}\"",
    "format": "prettier --config ../.prettierrc --write \"**/*.{js,jsx,ts,tsx,md}\""
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
