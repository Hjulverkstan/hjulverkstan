    "@tanstack/react-query-devtools": "^5.99.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "express": "^4.19.2",
    "globals": "^17.5.0",
    "lint-staged": "^16.4.0",
