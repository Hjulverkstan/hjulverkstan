    "@tiptap/html": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "0.2.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "http-proxy-middleware": "^3.0.5",
    "intl-messageformat": "^11.2.1",
